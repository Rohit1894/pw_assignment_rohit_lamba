# Copy this into Streamlit Cloud → your app → Settings → Secrets (paste the
# contents, NOT the filename). Do NOT commit real keys — this .example file is
# safe to commit; a real secrets.toml must stay gitignored.

GEMINI_API_KEY = "your-gemini-key-here"
# GOOGLE_API_KEY = "alternative-name-also-accepted"
SARVAM_API_KEY = "your-sarvam-key-here"

# Whisper is skipped by default on the free tier; leave this as "1".
SKIP_WHISPER = "1"
